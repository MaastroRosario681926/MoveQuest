import 'package:flutter/material.dart';

void main() => runApp(const MyApp());

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return const MaterialApp(
      debugShowCheckedModeBanner: false,
      home: HomePage(),
    );
  }
}

class HomePage extends StatefulWidget {
  const HomePage({super.key});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  final List<String> deck = List.generate(10, (index) => 'Carta Pokemon ${index + 1}');
  final List<String> nftDeck = List.generate(10, (index) => 'NFT Card ${index + 1}');
  final List<String> greenDeck = List.generate(10, (index) => 'Green Card ${index + 1}');
  final List<String> chooseDeck = List.generate(10, (index) => 'Choose Card ${index + 1}');
  final List<String> socialDeck = List.generate(10, (index) => 'Social Card ${index + 1}');
  
  bool isDeckOpen = false;
  bool isNftDeckOpen = false;
  bool isGreenDeckOpen = false;
  bool isChooseDeckOpen = false;
  bool isSocialDeckOpen = false;
  int devClickCount = 0;

  void _handleDevClick() {
    devClickCount++;
    if (devClickCount == 5) {
      devClickCount = 0;
      Navigator.push(
        context,
        MaterialPageRoute(builder: (context) => const DevPage()),
      );
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        backgroundColor: Colors.red.shade700,
        title: GestureDetector(
          onTap: _handleDevClick,
          child: const Text(
            'MoveQuest',
            style: TextStyle(fontWeight: FontWeight.bold),
          ),
        ),
      ),
      drawer: Drawer(
        child: ListView(
          padding: EdgeInsets.zero,
          children: [
            DrawerHeader(
              decoration: BoxDecoration(color: Colors.red.shade700),
              child: const Text(
                'Menu Gioco',
                style: TextStyle(color: Colors.white, fontSize: 24, fontWeight: FontWeight.bold),
              ),
            ),
            ListTile(
              leading: const Icon(Icons.home),
              title: const Text('Home', style: TextStyle(fontWeight: FontWeight.bold)),
              onTap: () {
                setState(() {
                  isDeckOpen = false;
                  isNftDeckOpen = false;
                  isGreenDeckOpen = false;
                  isChooseDeckOpen = false;
                  isSocialDeckOpen = false;
                });
                Navigator.pop(context);
              },
            ),
            ListTile(
              leading: const Icon(Icons.style),
              title: const Text('Il mio Mazzo', style: TextStyle(fontWeight: FontWeight.bold)),
              onTap: () {
                setState(() {
                  isDeckOpen = true;
                  isNftDeckOpen = false;
                  isGreenDeckOpen = false;
                  isChooseDeckOpen = false;
                  isSocialDeckOpen = false;
                });
                Navigator.pop(context);
              },
            ),
            ListTile(
              leading: const Icon(Icons.settings),
              title: const Text('Impostazioni', style: TextStyle(fontWeight: FontWeight.bold)),
              onTap: () => Navigator.pop(context),
            ),
          ],
        ),
      ),
      body: Center(
        child: _buildBody(),
      ),
    );
  }

  Widget _buildBody() {
    if (isDeckOpen) {
      return _buildDeckView(deck, const Color(0xFF00FFFF));
    } else if (isNftDeckOpen) {
      return _buildDeckView(nftDeck, const Color(0xFFFFAC1C));
    } else if (isGreenDeckOpen) {
      return _buildDeckView(greenDeck, const Color(0xFFFFD700));
    } else if (isChooseDeckOpen) {
      return _buildDeckView(chooseDeck, const Color(0xFF39FF14));
    } else if (isSocialDeckOpen) {
      return _buildDeckView(socialDeck, const Color(0xFFB0B0B0));
    } else {
      // Disposizione a 5 di un dado
      return Container(
        padding: const EdgeInsets.all(20),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            // Fila superiore (Phantom e N.F.T.)
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceEvenly,
              children: [
                GestureDetector(
                  onTap: () => setState(() => isDeckOpen = true),
                  child: _buildClosedDeck(const Color(0xFF00FFFF), "Phantom", isShiny: true),
                ),
                GestureDetector(
                  onTap: () => setState(() => isNftDeckOpen = true),
                  child: _buildClosedDeck(const Color(0xFFFFAC1C), "N.F.T.", isShiny: true),
                ),
              ],
            ),
            const SizedBox(height: 20),
            // Centro (Social)
            GestureDetector(
              onTap: () => setState(() => isSocialDeckOpen = true),
              child: _buildClosedDeck(const Color(0xFFB0B0B0), "Social", isShiny: true),
            ),
            const SizedBox(height: 20),
            // Fila inferiore (Hatchery e Choose)
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceEvenly,
              children: [
                GestureDetector(
                  onTap: () => setState(() => isGreenDeckOpen = true),
                  child: _buildClosedDeck(const Color(0xFFFFD700), "Hatchery", isShiny: true),
                ),
                GestureDetector(
                  onTap: () => setState(() => isChooseDeckOpen = true),
                  child: _buildClosedDeck(const Color(0xFF39FF14), "Choose", isShiny: true),
                ),
              ],
            ),
          ],
        ),
      );
    }
  }

  Widget _buildDeckView(List<String> currentList, Color color) {
    return Stack(
      children: [
        PageView.builder(
          scrollDirection: Axis.vertical,
          itemCount: currentList.length,
          itemBuilder: (context, index) {
            return Center(child: _buildCard(currentList[index], color));
          },
        ),
        Positioned(
          bottom: 20,
          right: 20,
          child: SizedBox(
            width: 28,
            height: 28,
            child: FloatingActionButton(
              backgroundColor: Colors.red.shade700,
              onPressed: () {
                setState(() {
                  isDeckOpen = false;
                  isNftDeckOpen = false;
                  isGreenDeckOpen = false;
                  isChooseDeckOpen = false;
                  isSocialDeckOpen = false;
                });
              },
              child: const Icon(Icons.home, color: Colors.white, size: 16),
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildClosedDeck(Color color, String label, {bool isShiny = false}) {
    return SizedBox(
      width: 140,
      height: 100,
      child: Stack(
        alignment: Alignment.center,
        children: List.generate(3, (index) {
          return Transform.translate(
            offset: Offset(index * 3.0, index * 3.0),
            child: Container(
              width: 130,
              height: 90,
              decoration: BoxDecoration(
                color: color,
                gradient: isShiny ? LinearGradient(
                  begin: Alignment.topLeft,
                  end: Alignment.bottomRight,
                  colors: _getGradientColors(color),
                  stops: const [0.1, 0.5, 0.9],
                ) : null,
                borderRadius: BorderRadius.circular(10),
                border: Border.all(color: Colors.white, width: 2),
                boxShadow: const [BoxShadow(color: Colors.black45, blurRadius: 5)],
              ),
              child: Center(
                child: Column(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    const Icon(Icons.catching_pokemon, color: Colors.white, size: 30),
                    Text(
                      label,
                      style: const TextStyle(
                        color: Colors.white,
                        fontSize: 14,
                        fontWeight: FontWeight.bold,
                        shadows: [Shadow(color: Colors.black, blurRadius: 1)],
                      ),
                    ),
                  ],
                ),
              ),
            ),
          );
        }),
      ),
    );
  }

  List<Color> _getGradientColors(Color baseColor) {
    if (baseColor == const Color(0xFF00FFFF)) {
      return [const Color(0xFFE0FFFF), const Color(0xFF00FFFF), const Color(0xFF00CED1)];
    } else if (baseColor == const Color(0xFFFFD700)) {
      return [const Color(0xFFFFF9C4), const Color(0xFFFFEB3B), const Color(0xFFFFD700)];
    } else if (baseColor == const Color(0xFFFFAC1C)) {
      return [const Color(0xFFFFD580), const Color(0xFFFFAC1C), const Color(0xFFFF8C00)];
    } else if (baseColor == const Color(0xFF39FF14)) {
      return [const Color(0xFFCCFF00), const Color(0xFF39FF14), const Color(0xFF00FF00)];
    } else if (baseColor == const Color(0xFFB0B0B0)) {
      return [const Color(0xFFF5F5F5), const Color(0xFFB0B0B0), const Color(0xFF696969)];
    }
    return [baseColor, baseColor, baseColor];
  }

  Widget _buildCard(String title, Color color) {
    bool isFluorescent = color == const Color(0xFF00FFFF) || 
                        color == const Color(0xFFFFD700) || 
                        color == const Color(0xFF39FF14) ||
                        color == const Color(0xFFB0B0B0) ||
                        color == const Color(0xFFFFAC1C);
    return Container(
      width: 300,
      height: 450,
      decoration: BoxDecoration(
        color: color,
        gradient: isFluorescent ? LinearGradient(
                  begin: Alignment.topLeft,
                  end: Alignment.bottomRight,
                  colors: _getGradientColors(color),
                ) : null,
        borderRadius: BorderRadius.circular(15),
        border: Border.all(color: Colors.white, width: 10),
        boxShadow: const [BoxShadow(color: Colors.black45, blurRadius: 15, offset: Offset(5, 5))],
      ),
      child: Column(
        children: [
          Padding(
            padding: const EdgeInsets.all(12),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                Text(title, style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 18, color: Colors.white)),
                const Text('HP 120', style: TextStyle(fontWeight: FontWeight.bold, color: Colors.redAccent, fontSize: 16)),
              ],
            ),
          ),
          Expanded(
            child: Container(
              margin: const EdgeInsets.symmetric(horizontal: 15),
              decoration: BoxDecoration(
                color: Colors.blueGrey.shade100,
                border: Border.all(color: Colors.grey.shade400, width: 3),
              ),
              child: Center(child: Icon(Icons.catching_pokemon, size: 80, color: color)),
            ),
          ),
          const Padding(
            padding: EdgeInsets.all(20),
            child: Text(
              "Attacco Speciale\nDescrizione della mossa speciale qui.",
              textAlign: TextAlign.center,
              style: TextStyle(fontSize: 14, fontWeight: FontWeight.bold, color: Colors.white),
            ),
          ),
        ],
      ),
    );
  }
}

class DevPage extends StatelessWidget {
  const DevPage({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("PAGINA DEV")),
      body: const Center(
        child: Text("Benvenuto nella sezione Developer", style: TextStyle(fontSize: 20)),
      ),
    );
  }
}
